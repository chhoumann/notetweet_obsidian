{
	"name": "notetweet",
	"version": "0.6.7",
	"description": "Post tweets and threads to X (Twitter) directly from your notes.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "pnpm run typecheck && node esbuild.config.mjs production",
		"typecheck": "tsc --noEmit",
		"lint": "eslint . --max-warnings=0",
		"test": "vitest run --passWithNoTests",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"typecheck:e2e": "tsc --noEmit -p tsconfig.e2e.json",
		"test:e2e": "pnpm run build && pnpm run typecheck:e2e && vitest run --config vitest.e2e.config.ts",
		"obsidian:e2e": "obsidian-e2e run",
		"provision:e2e-vault": "obsidian-e2e provision",
		"start:e2e-obsidian": "obsidian-e2e start",
		"stop:e2e-obsidian": "obsidian-e2e stop"
	},
	"keywords": [
		"obsidian",
		"twitter",
		"x",
		"plugin"
	],
	"author": "Christian Bager Bach Houmann",
	"license": "MIT",
	"packageManager": "pnpm@10.32.1",
	"engines": {
		"node": ">=20.18.1"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/chhoumann/notetweet_obsidian.git"
	},
	"devDependencies": {
		"@types/node": "^26.0.1",
		"@vitest/coverage-v8": "^4.1.9",
		"esbuild": "0.28.1",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"globals": "^17.7.0",
		"obsidian": "1.13.1",
		"obsidian-e2e": "^0.8.2",
		"obsidian-test-kit": "^0.1.0",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.0",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"crypto-es": "^2.1.0",
		"twitter-text": "3.1.0",
		"unicode-segmenter": "0.17.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}
